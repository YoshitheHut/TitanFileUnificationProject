		titan_footstep_damage_height_check_ratio 0.15

		ClassMods
		{
			pas_dash_recharge
			{
		        powerregenrate	2.5++
			}
			sflag_bc_dash_capacity
			{
				dodgePowerDrain		50
				powerregenrate		3++
			}
			pas_titan_punch
			{
				meleeDamage 500++
			}
			pas_burst_boosters
			{
				dodgeSpeed	250++
				powerregenrate	8--
			}
			pas_doomed_time
			{
				doomStateMoveSpeedScale 1
				doomStateAccelScale 1
			}
			pas_flight_core
			{
				dodgeSpeed			350
       			dodgeStopSpeed		400
       			dodgeHeight			0
			}
		}
	}
