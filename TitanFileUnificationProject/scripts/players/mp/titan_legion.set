		deathcamMinHeight			60

		chasecamMaxOrbitDepth		120

		impactSpeed 1000

		meleeDamage 2000
		meleePushback 600
		meleeLungeSpeed 400

		sound_superJump			""
		sound_superJumpFail		""
		sound_dodge				"Ogre.Dash"
		sound_dodgeFail			"Player.DodgeFail"
		sound_groundImpact		"Titan.GroundImpact"
		sound_wallrunImpact		""
