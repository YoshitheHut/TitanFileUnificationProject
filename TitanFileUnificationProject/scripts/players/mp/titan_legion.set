		physicsMass				3000
		physicsIgnoreBelowMass	500
		physicsSoftBelowMass	1000
		physicsPushMassLimit	5000
		physicsPushSpeedLimit	200

		damageImpulseScale		0.4
		damageImpulseScaleAir	0.1
		damageImpulseSpeedBoostLimit	930
		damageImpulseSpeedLossLimit		930

		model				"models/titans/heavy/titan_heavy_deadbolt.mdl"//titan_heavy_scorch_prime
		bodymodel_imc		"models/titans/heavy/titan_heavy_deadbolt.mdl"
		bodymodel_militia	"models/titans/heavy/titan_heavy_deadbolt.mdl"
		armsmodel_imc		"models/weapons/arms/pov_titan_heavy_deadbolt.mdl"
