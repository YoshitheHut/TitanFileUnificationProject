		footstepAccelReduce 1

		magneticRange	190

		aimAngleBackwardEnd		-120
		aimAngleForwardStart	-40
		aimAngleForwardEnd		40
		aimAngleBackwardStart	120

		doomStateMoveSpeedScale	0.75
		doomStateAccelScale  	0.75

